# Router 默认后端地址
ROUTER_BACKEND_URL=http://127.0.0.1:3011

# 中心化 UCAN 认证服务地址（Node 服务）
CENTRAL_UCAN_AUTH_BASE_URL=http://127.0.0.1:8100

# 中心化 UCAN clientId（在 Node 中已发布应用 AppId）
CENTRAL_UCAN_CLIENT_ID=

# 中心化 UCAN appName（授权页展示）
CENTRAL_UCAN_APP_NAME=

# 登录路径强制模式（auto=自动优先钱包并回退服务；wallet=仅钱包；central=仅服务授权）
UCAN_LOGIN_FORCE_MODE=auto

# WebDAV 默认后端地址
WEBDAV_BACKEND_BASE_URL=http://127.0.0.1:6065

# WebDAV 路径前缀（默认 /dav）
WEBDAV_BACKEND_PREFIX=/dav

# 启用 MCP（可选，true 表示启用）
ENABLE_MCP=
